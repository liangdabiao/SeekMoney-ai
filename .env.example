# ============================================================================
# SeekMoney AI 环境变量模板
# 复制本文件为 .env.local，然后填入你自己的 API Key
# 切勿把真实 key 提交到版本控制
# ============================================================================

# 一、智谱 AI GLM API 配置 (推荐)
# 注册地址: https://open.bigmodel.cn/
GLM_API_KEY=your_glm_api_key_here
GLM_MODEL_NAME=glm-4.6
# 语义聚类使用的 Embedding 模型
GLM_EMBEDDING_MODEL=embedding-3
GLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4/chat/completions
GLM_BASE_EMBEDDING_URL=https://open.bigmodel.cn/api/paas/v4/embeddings

# 二、GPT 代理 API 配置 (openai 兼容，可选，二选一)
# GLM_API_KEY=your_openai_compatible_api_key_here
# GLM_MODEL_NAME=gpt-4o-mini
# GLM_EMBEDDING_MODEL=text-embedding-3-small
# GLM_BASE_URL=https://your-proxy.com/v1/chat/completions
# GLM_BASE_EMBEDDING_URL=https://your-proxy.com/v1/embeddings

# Embedding 提供商选择: 'auto' | 'openai' | 'zhipuai'
EMBEDDING_PROVIDER=zhipuai

# 三、TikHub API (数据抓取服务)
# 注册地址: https://tikhub.io/
TIKHUB_API_TOKEN=your_tikhub_token_here
TIKHUB_TIMEOUT=60000
# 设为 true 走中国区加速域名
# TIKHUB_USE_CHINA_DOMAIN=true

# ============================================================================
# 以下一般无需修改
# ============================================================================

# Python 配置
PYTHONIOENCODING=utf-8

# 浏览器配置
# 服务器环境推荐设为 true 使用无头模式
HEADLESS=false

# 日志级别 (info/debug/error)
LOG_LEVEL=info

# 分析结果存储目录（可配置到 /tmp 等可写位置；serverless 环境慎用本地写）
# SEAGULL_STORAGE_DIR=./analysis-results

# 开发环境配置
NODE_ENV=development
